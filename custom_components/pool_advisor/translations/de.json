        "title": "Zielwerte & Toleranzen",
        "description": "Defaults sind Richtwerte aus der Pool-Chemie-Literatur. Blöcke sind einklappbar.",
        "sections": {
          "ph": {
            "name": "pH-Wert",
            "description": "Säure-Base-Wert des Wassers. Bestimmt sowohl Baden-Komfort (Augen/Haut) als auch Chlor-Wirksamkeit — bei höherem pH fällt der Anteil aktiver Hypochloriger Säure. Ziel 7.0–7.4.",
            "data": {
              "ph_min": "pH min",
              "ph_target": "pH Ziel",
              "ph_max": "pH max",
              "ph_critical_low": "pH kritisch niedrig (eingreifen unterhalb)",
              "ph_critical_high": "pH kritisch hoch (eingreifen oberhalb)"
            }
          },
          "alkalinity": {
            "name": "Alkalität (TA)",
            "description": "Karbonathärte — Puffer gegen pH-Schwankungen. Zu wenig und pH pendelt bei jeder Dosis, zu viel macht pH-Regulierung zäh und fördert Kalkausfällung. Ziel 80–120 mg/l.",
            "data": {
              "ta_min": "Alkalität min (mg/l)",
              "ta_target": "Alkalität Ziel (mg/l)",
              "ta_max": "Alkalität max (mg/l)",
              "ta_critical_low": "Alkalität kritisch niedrig (mg/l)",
              "ta_critical_high": "Alkalität kritisch hoch (mg/l)"
            }
          },
          "cyanuric": {
            "name": "Cyanursäure",
            "description": "Stabilisator — bindet Chlor reversibel und schützt es vor UV-Abbau. Ohne CYA verbrennt Chlor in Stunden; zu viel CYA blockiert Chlor so dass es kaum noch desinfiziert. Sweet Spot 30–50 mg/l.",
            "data": {
              "cya_min": "Cyanursäure min (mg/l)",
              "cya_target": "Cyanursäure Ziel (mg/l)",
              "cya_max": "Cyanursäure max (mg/l)",
              "cya_critical_low": "Cyanursäure kritisch niedrig (0 = aus)",
              "cya_critical_high": "Cyanursäure kritisch hoch (mg/l)"
            }
          },
          "free_chlorine": {
            "name": "Freies Chlor",
            "description": "Aktiver Sanitizer im Wasser — tötet Bakterien, Viren und Algen. Zu niedrig = Keime wachsen schneller als Chlor sie abbaut, zu hoch reizt Augen und Haut. Die wirksame Fraktion hängt am CYA-Level.",
            "data": {
              "fc_min": "Freies Chlor min (mg/l)",
              "fc_target": "Freies Chlor Ziel (mg/l)",
              "fc_max": "Freies Chlor max (mg/l)",
              "fc_critical_low": "Freies Chlor kritisch niedrig (mg/l)",
              "fc_critical_high": "Freies Chlor kritisch hoch (mg/l, Bade-Sperre)"
            }
          },
          "combined_chlorine": {
            "name": "Gebundenes Chlor",
            "description": "Verbrauchte Chlor-Verbindungen — entstehen durch Reaktion mit Haut, Haar, Schweiß, Urin. Der typische \"Chlor-Geruch\" kommt davon, nicht vom aktiven Chlor. Hoch = hohe Bade-Belastung, Breakpoint-Chlorung fällig.",
            "data": {
              "cc_max": "Gebundenes Chlor max (mg/l, beobachten)",
              "cc_critical_high": "Gebundenes Chlor kritisch hoch (mg/l, Shockchlorung)"
            }
          },
          "redox": {
            "name": "Redox (ORP)",
            "description": "Oxidationspotenzial in mV — Summen-Maß wie gut das Wasser desinfizieren kann. Die Dosieranlage regelt darauf; hier ist der Wert primär Diagnose: &lt; 650 unterversorgt, ~700 ideal, &gt; 800 verdächtig hoch.",
            "data": {
              "redox_min": "Redox min (mV)",
              "redox_target": "Redox Ziel (mV)",
              "redox_max": "Redox max (mV)",
              "redox_critical_low": "Redox kritisch niedrig (mV, Diagnose-Alarm)",
              "redox_critical_high": "Redox kritisch hoch (mV, Diagnose-Alarm)"
            }
          },
          "drift": {
            "name": "Sonden-Drift",
            "description": "Elektroden der Dosieranlage altern und driften. Der Advisor vergleicht pH-Sonde gegen Photometer und Redox-Sonde gegen chemisch berechneten Erwartungswert. Bei Überschreiten → Nachkalibrieren.",
            "data": {
              "ph_calibration_threshold": "Drift-Schwelle pH Sonde (Abweichung Auto↔Manuell)",
              "redox_drift_threshold": "Drift-Schwelle Redox Sonde (mV)"
            }
          },
